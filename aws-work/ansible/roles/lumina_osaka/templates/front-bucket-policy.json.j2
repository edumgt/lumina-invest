{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCloudFrontServicePrincipalReadOnly",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudfront.amazonaws.com"
      },
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::{{ lumina_osaka.buckets.front }}/*",
      "Condition": {
        "StringEquals": {
          "AWS:SourceArn": "{{ lumina_osaka_cloudfront_arn }}"
        }
      }
    }
  ]
}
