PORT=8000
BASE_URL=https://agent.example.local

# In Kubernetes, prefer internal service DNS between pods.
# VIPs are useful for external access, but agent -> ollama/qdrant traffic
# should usually stay on ClusterIP/service DNS.
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.1
EMBED_MODEL=nomic-embed-text

SQLITE_PATH=/data/app.db
SESSION_SECRET=change-me-prod

RAW_DIR=./data/raw
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
TOP_K=6
MAX_CONTEXT_CHUNKS=10
DOC_VERSION_STRATEGY=latest

VECTOR_STORE=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=law_chunks

ADMIN_EMAILS=
TRUST_PROXY=1
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
OLLAMA_TIMEOUT_MS=300000
