PORT=8000
BASE_URL=http://localhost:8000

# WSL agent -> Windows host Ollama
# Update this IP if the Windows host gateway changes.
OLLAMA_BASE_URL=http://172.29.32.1:11434
LLM_MODEL=llama3.1
EMBED_MODEL=nomic-embed-text

# Local SQLite metadata DB in WSL
SQLITE_PATH=./data/app.db
SESSION_SECRET=dev-secret

RAW_DIR=./data/raw
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
TOP_K=6
MAX_CONTEXT_CHUNKS=10
DOC_VERSION_STRATEGY=latest

# Docker Qdrant exposed to WSL host
VECTOR_STORE=qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=law_chunks

ADMIN_EMAILS=
TRUST_PROXY=0
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
OLLAMA_TIMEOUT_MS=300000
